@model PaginatedList<MotorcycleShopMVC.Models.Part>

@{
    ViewData["Title"] = "Danh sách Phụ tùng";
}

<h1>Danh sách Phụ tùng</h1>

<table class="table table-striped table-hover mt-3">
    <thead class="thead-dark">
        <tr>
            <th>Hình ảnh</th>
            <th>Tên phụ tùng</th>
            <th>Thương hiệu</th>
            <th>Loại (Danh mục)</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@Url.Content("~/" + item.ImagePath)" alt="@item.PartName" style="max-width: 100px; max-height: 80px; object-fit: cover;" />
                </td>
                <td class="align-middle font-weight-bold">@item.PartName</td>
                <td class="align-middle">@item.Brand.BrandName</td>
                <td class="align-middle">@item.Category.CategoryName</td>
                <td class="align-middle text-danger font-weight-bold">@item.Price.ToString("N0") đ</td>
                <td class="align-middle">@item.StockQuantity</td>
                <td class="align-middle">
                    <a asp-action="Details" asp-route-id="@item.PartId" class="btn btn-info btn-sm">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-4 d-flex align-items-center">
    <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex - 1)"
           class="btn btn-outline-primary @(!Model.HasPreviousPage ? "disabled" : "")">
        &laquo; Trang trước
    </a>

    <span class="mx-3 font-weight-bold">Trang @Model.PageIndex / @Model.TotalPages</span>

    <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex + 1)"
           class="btn btn-outline-primary @(!Model.HasNextPage ? "disabled" : "")">
        Trang sau &raquo;
    </a>
</div>