@model MotorcycleShopMVC.Models.Part

@{
    ViewData["Title"] = "Chi tiết Phụ tùng";
}

<div class="container mt-4">
    <h2 class="mb-4">@Model.PartName</h2>
    <hr />
    
    <div class="row">
        <div class="col-md-5 text-center">
            <img src="@Url.Content("~/" + Model.ImagePath)" alt="@Model.PartName" class="img-fluid rounded border shadow-sm" style="max-height: 400px; width: auto;" />
        </div>
        
        <div class="col-md-7">
            <h3 class="text-danger font-weight-bold mb-3">@Model.Price.ToString("N0") VNĐ</h3>
            
            <table class="table table-borderless">
                <tbody>
                    <tr>
                        <th style="width: 30%">Thương hiệu:</th>
                        <td>@Model.Brand.BrandName</td>
                    </tr>
                    <tr>
                        <th>Danh mục:</th>
                        <td>@Model.Category.CategoryName</td>
                    </tr>
                    <tr>
                        <th>Bảo hành:</th>
                        <td>@Model.WarrantyMonths tháng</td>
                    </tr>
                    <tr>
                        <th>Tồn kho:</th>
                        <td>
                            @if (Model.StockQuantity > 0)
                            {
                                <span class="badge bg-success text-white">Còn @Model.StockQuantity sản phẩm</span>
                            }
                            else
                            {
                                <span class="badge bg-danger text-white">Hết hàng</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="mt-3">
                <h5>Mô tả:</h5>
                <p class="text-muted" style="line-height: 1.6;">@Model.Description</p>
            </div>
            
            <hr />
            <div class="mt-4">
                <button class="btn btn-success btn-lg px-4" @(Model.StockQuantity <= 0 ? "disabled" : "")>
                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg ms-2">
                    Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>