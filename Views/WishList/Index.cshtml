@model IEnumerable<MotorcycleShopMVC.Models.Wishlist>

@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["WishlistMessage"] != null)
{
    <div class="alert alert-info">
        @TempData["WishlistMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="text-center">
        <p>Danh sách yêu thích của bạn đang trống.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Bắt đầu mua sắm</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100">
                    @if (item.Motorcycle != null)
                    {
                        <img src="@Url.Content("~/" + item.Motorcycle.ImagePath)" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@item.Motorcycle.ModelName">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Motorcycle.ModelName</h5>
                            <p class="card-text text-muted">@item.Motorcycle.Brand?.BrandName</p>
                            <h6 class="text-danger mt-auto">@item.Motorcycle.Price.ToString("N0") VNĐ</h6>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 text-center">
                            <a asp-controller="Motorcycle" asp-action="Detail" asp-route-id="@item.MotorcycleId" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                        </div>
                    }
                    else if (item.Part != null)
                    {
                        <img src="@Url.Content("~/" + item.Part.ImagePath)" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@item.Part.PartName">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Part.PartName</h5>
                            <p class="card-text text-muted">@item.Part.Brand?.BrandName</p>
                            <h6 class="text-danger mt-auto">@item.Part.Price.ToString("N0") VNĐ</h6>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 text-center">
                            <a asp-controller="Part" asp-action="Detail" asp-route-id="@item.PartId" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                        </div>
                    }

                    <div class="card-footer text-center">
                        <form asp-controller="Wishlist" asp-action="Remove" asp-route-id="@item.WishlistId" method="post">
                            <button type="submit" class="btn btn-sm btn-danger">Xóa khỏi danh sách</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
