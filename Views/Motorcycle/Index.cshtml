@model PaginatedList<MotorcycleShopMVC.Models.Motorcycle>

@{
    ViewData["Title"] = "Danh sách xe";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm xe mới</a>
</p>

@* FORM LỌC VÀ TÌM KIẾM *@
<form asp-action="Index" method="get">
    <div class="row mb-3">
        <div class="col-md-3">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Tìm theo tên xe..." />
        </div>
        <div class="col-md-2">
            <select name="brandId" asp-items="@(ViewData["BrandId"] as SelectList)" class="form-control">
                <option value="">Tất cả hãng</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="typeId" asp-items="@(ViewData["TypeId"] as SelectList)" class="form-control">
                <option value="">Tất cả loại xe</option>
            </select>
        </div>
        <div class="col-md-2">
            <select name="yearFrom" asp-items="@(ViewData["YearFrom"] as SelectList)" class="form-control">
                <option value="">Tất cả các năm</option>
            </select>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-3">
            <select name="priceRange" asp-items="@(ViewData["PriceRanges"] as SelectList)" class="form-control">
                <option value="">Tất cả các mức giá</option>
            </select>
        </div>
        <div class="col-md-3">
            <select name="engineRange" asp-items="@(ViewData["EngineRanges"] as SelectList)" class="form-control">
                <option value="">Tất cả dung tích</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="submit" value="Tìm kiếm" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Reset</a>
        </div>
    </div>
</form>


<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Hình ảnh</th>
            <th>Tên xe</th>
            <th>Hãng</th>
