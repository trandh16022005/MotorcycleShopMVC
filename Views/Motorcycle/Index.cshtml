@model IEnumerable<MotorcycleShopMVC.Models.Motorcycle>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ModelName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EngineCapacity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.YearFrom)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.YearTo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Color)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.WarrantyPolicy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImagePath)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StockQty)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UpdatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Brand)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Type)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ModelName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EngineCapacity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.YearFrom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.YearTo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Color)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WarrantyPolicy)
            </td>
            <td>
                    <img src="@Url.Content("~/" + item.ImagePath)" alt="Hình xe" style="max-width:120px; max-height:80px;" />
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StockQty)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Brand.BrandId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Type.TypeId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MotorcycleId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MotorcycleId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MotorcycleId">Delete</a>
                <form asp-controller="Cart" asp-action="AddMotorcycle" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="motorcycleId" value="@item.MotorcycleId" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-sm btn-success">Thêm vào giỏ</button>                       
                </form>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        function getCsrfToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        }

        async function addToCart(motorcycleId) {
            const tokenInput = document.querySelector('form input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            const formData = new FormData();
            formData.append('motorcycleId', motorcycleId);
            formData.append('quantity', 1);
            if (token) formData.append('__RequestVerificationToken', token);

            const res = await fetch('/Cart/AddMotorcycle', {
                method: 'POST',
                body: formData
            });

            const data = await res.json();
            if (data.success) {
                const countEl = document.getElementById('cart-count');
                if (countEl) countEl.innerText = data.count;
            }
        }

        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.add-to-cart-btn');
            if (!btn) return;
            const id = btn.getAttribute('data-id');
            addToCart(id);
        });
    </script>
}
