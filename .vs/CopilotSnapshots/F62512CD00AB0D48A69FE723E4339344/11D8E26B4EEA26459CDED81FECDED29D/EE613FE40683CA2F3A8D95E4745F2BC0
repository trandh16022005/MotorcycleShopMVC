using Microsoft.AspNetCore.Mvc;
using MotorcycleShopMVC.Models;
using System.Diagnostics;
using MotorcycleShopMVC.Services;
using MotorcycleShopMVC.ViewModels;

namespace MotorcycleShopMVC.Controllers
{
    public class HomeController : Controller
    {
        private readonly ILogger<HomeController> _logger;
        private readonly IProductService _productService;

        public HomeController(ILogger<HomeController> logger, IProductService productService)
        {
            _logger = logger;
            _productService = productService;
        }

        public IActionResult Index()
        {
            const int featuredCount = 8;
            const int latestCount = 8;

            var featured = _productService.GetFeaturedMotorcycles(featuredCount);
            var latest = _productService.GetLatestMotorcycles(latestCount);

            var model = new HomeViewModel
            {
                FeaturedProducts = featured.Select(m => new ProductItemViewModel
                {
                    Id = m.MotorcycleId,
                    Name = m.ModelName,
                    Price = m.Price,
                    ImageUrl = string.IsNullOrWhiteSpace(m.ImagePath) ? "/images/motorcycles/placeholder.png" : $"/images/{m.ImagePath.TrimStart('~','/')}
                }).ToList()),

                LatestProducts = latest.Select(m => new ProductItemViewModel
                {
                    Id = m.MotorcycleId,
                    Name = m.ModelName,
                    Price = m.Price,
                    ImageUrl = string.IsNullOrWhiteSpace(m.ImagePath) ? "/images/motorcycles/placeholder.png" : $"/images/{m.ImagePath.TrimStart('~','/')}
                }).ToList()
            };

            return View(model);
        }

        public IActionResult Privacy()
        {
            return View();
        }

        [ResponseCache(Duration = 0, Location = ResponseCacheLocation.None, NoStore = true)]
        public IActionResult Error()
        {
            return View(new ErrorViewModel { RequestId = Activity.Current?.Id ?? HttpContext.TraceIdentifier });
        }
    }
}
