@model IEnumerable<MotorcycleShopMVC.Models.Motorcycle>

@{
    ViewData["Title"] = "MotorcycleShop";
}

<style>
    :root{
        --primary: #ee4d2d;
        --secondary: #f5f5f5;
        --card-radius: 8px;
        --card-shadow: 0 6px 18px rgba(0,0,0,0.08);
    }

    body { background: #ffffff; }

    .site-header { padding: 1rem 0; }
    .logo { font-weight: 700; color: var(--primary); font-size: 1.4rem; }

    .search-input .form-control { border-radius: 24px; border: 1px solid #e9e9e9; }

    .category-menu { background: transparent; padding: .5rem 0; }
    .category-menu .nav-link { color: #333; border-radius: 6px; padding: .5rem 1rem; }
    .category-menu .nav-link:hover{ background: var(--secondary); color: var(--primary); }

    .hero-banner { height: 300px; border-radius: var(--card-radius); overflow: hidden; background-size: cover; background-position: center; box-shadow: var(--card-shadow); }

    .product-card { border-radius: var(--card-radius); box-shadow: var(--card-shadow); overflow: hidden; transition: transform .18s ease, box-shadow .18s ease; background: #fff; }
    .product-card:hover{ transform: translateY(-6px) scale(1.02); box-shadow: 0 14px 30px rgba(0,0,0,0.12); }
    .product-card .card-body { padding: .9rem; }
    .product-title { font-size: .98rem; min-height: 2.4rem; line-height: 1.2; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
    .product-price { color: var(--primary); font-weight: 700; }

    .product-img { height: 180px; object-fit: cover; width: 100%; }

    .btn-primary-custom{ background: var(--primary); border-color: var(--primary); }

    footer.site-footer { padding: 2rem 0; color: #666; font-size: .9rem; }

    @media (max-width: 576px){ .search-input { margin-top: .6rem; } }
</style>

<div class="container">
    <!-- HEADER -->
    <header class="d-flex align-items-center justify-content-between site-header">
        <div class="d-flex align-items-center gap-3">
            <div class="logo">MotorcycleShop</div>
        </div>

        <div class="flex-fill px-4 search-input d-none d-md-block">
            <form asp-controller="Motorcycle" asp-action="Index" method="get">
                <div class="input-group">
                    <input type="text" name="q" class="form-control" placeholder="Search motorcycles, parts, accessories...">
                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center">
            <a class="text-decoration-none text-dark position-relative" asp-controller="Cart" asp-action="Index">
                <i class="bi bi-cart" style="font-size:1.4rem;"></i>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
            </a>
        </div>
    </header>

    <!-- CATEGORY MENU -->
    <nav class="category-menu">
        <ul class="nav justify-content-center">
            <li class="nav-item"><a class="nav-link" asp-controller="Motorcycle" asp-action="Index" asp-route-category="Scooter">Scooter</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Motorcycle" asp-action="Index" asp-route-category="Manual">Manual</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Motorcycle" asp-action="Index" asp-route-category="Electric">Electric</a></li>
            <li class="nav-item"><a class="nav-link" asp-controller="Motorcycle" asp-action="Index" asp-route-category="Sport">Sport</a></li>
        </ul>
    </nav>

    <!-- HERO BANNER -->
    <div class="my-4 hero-banner" style="background-image: url('https://via.placeholder.com/1400x300?text=Hero+Banner');"></div>

    <!-- PRODUCT GRID -->
    <section class="mb-5">
        <div class="row g-3">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="product-card card h-100">
                            <img src="~/@item.ImagePath" class="product-img" alt="@item.ModelName" />
                            <div class="card-body d-flex flex-column">
                                <div class="mb-2 product-title">@item.ModelName</div>
                                <div class="mt-auto d-flex align-items-center justify-content-between">
                                    <div class="product-price">$@String.Format("{0:N0}", item.Price)</div>
                                    <a asp-action="Details" asp-route-id="@item.MotorcycleId" class="btn btn-sm btn-primary btn-primary-custom">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-secondary">No products found.</div>
                </div>
            }
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer text-center">
        <div class="border-top pt-3">
            &copy; @DateTime.Now.Year MotorcycleShop. All rights reserved.
        </div>
    </footer>
</div>
